			"responsibilities": [
				"Lideré la evolución técnica de plataformas de autogestión en el sector salud, con foco en estabilidad, escalabilidad y experiencia de usuario."
			],
			"achievements": [
				{
					"title": "Modernización Frontend",
					"content": "Lideré la migración de interfaces críticas a React y TypeScript, mejorando la mantenibilidad del código y facilitando la incorporación de nuevas funcionalidades del producto."
				},
				{
					"title": "Adaptación y UX",
					"content": "Lideré la transición de aplicaciones híbridas a diseños responsive y diseñé flujos de autenticación en Figma, prototipando soluciones junto a equipos de diseño y producto para mejorar la experiencia de usuario y reducir la fricción en procesos clave."
				},
				{
					"title": "Optimización de Core Business",
					"content": "Aseguré el mantenimiento y evolución de servicios Java EE (JBoss) y bases de datos MS SQL Server, optimizando la lógica de negocio para procesos críticos de valorización médica y scoring de afiliados."
				},
				{
					"title": "Coordinación Técnica",
					"content": "Traduje requerimientos de negocio en soluciones técnicas, realizando análisis, estimaciones y documentación bajo estándares de calidad (ISO), y coordinando con equipos de producto, diseño e ingeniería para asegurar entregas alineadas al usuario."
				},
				{
					"title": "Seguridad e Integraciones",
					"content": "Lideré la migración de APIs críticas bajo estándares mTLS e implementé SSL Pinning en aplicaciones móviles para asegurar la comunicación segura con sistemas externos."
				},
				{
					"title": "Infraestructura y Cloud",
					"content": "Ejecuté la contenerización de servicios de geolocalización con Docker y Kubernetes (Tanzu), asegurando despliegues estables en producción."
				},
				{
					"title": "Calidad y Testing",
					"content": "Diseñé y ejecuté casos de prueba funcionales para validar flujos críticos, asegurando la calidad de las entregas."
				}
			],
